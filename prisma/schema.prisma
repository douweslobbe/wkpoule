generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  memberships       PoolMembership[]
  predictions       Prediction[]
  bonusAnswers      BonusAnswer[]
  championPicks     ChampionPick[]
  poolMessages      PoolMessage[]
  achievements      Achievement[]
  survivorEntry     SurvivorEntry?
  pushSubscriptions   PushSubscription[]
  fantasyTeam         FantasyTeam?
  passwordResetTokens PasswordResetToken[]

  @@index([email])
}

model Pool {
  id          String   @id @default(cuid())
  name        String
  description String?
  inviteCode  String   @unique
  createdAt   DateTime @default(now())
  createdById String

  // Max bonusvragen per pool (instelbaar door admin)
  maxQuestionsTotal Int @default(25)
  maxQuestionsOpen  Int @default(10)
  maxQuestionsEst   Int @default(5)
  maxQuestionsStmt  Int @default(10)

  memberships    PoolMembership[]
  bonusQuestions BonusQuestion[]
  championPicks  ChampionPick[]
  leaderboard    LeaderboardEntry[]
  messages       PoolMessage[]
  achievements   Achievement[]
  predictions    Prediction[]
}

model PoolMembership {
  id       String   @id @default(cuid())
  userId   String
  poolId   String
  role     PoolRole @default(MEMBER)
  joinedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([userId, poolId])
  @@index([poolId])
}

enum PoolRole {
  ADMIN
  MEMBER
}

model Team {
  id         String  @id @default(cuid())
  name       String  @unique
  nameNl     String?
  code       String  @unique
  flagUrl    String?
  externalId Int?    @unique

  homeMatches   Match[]        @relation("HomeTeam")
  awayMatches   Match[]        @relation("AwayTeam")
  championPicks ChampionPick[]
  survivorPicks SurvivorPick[]
  players       Player[]
}

model Match {
  id           String      @id @default(cuid())
  externalId   Int         @unique
  stage        MatchStage
  groupName    String?
  matchday     Int?
  homeTeamId   String?
  awayTeamId   String?
  homeScore    Int?
  awayScore    Int?
  status       MatchStatus @default(SCHEDULED)
  kickoff      DateTime
  venue        String?
  lastSyncedAt       DateTime?
  notificationSentAt DateTime?

  homeTeam      Team?               @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam      Team?               @relation("AwayTeam", fields: [awayTeamId], references: [id])
  predictions   Prediction[]
  playerStats   FantasyPlayerStats[]

  @@index([stage])
  @@index([kickoff])
  @@index([status])
}

enum MatchStage {
  GROUP
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
}

model Prediction {
  id            String   @id @default(cuid())
  userId        String
  matchId       String
  poolId        String
  homeScore     Int
  awayScore     Int
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
  pointsAwarded Int?
  isJoker       Boolean  @default(false)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  pool  Pool  @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId, poolId])
  @@index([matchId])
  @@index([userId])
  @@index([poolId])
}

model Achievement {
  id        String   @id @default(cuid())
  userId    String
  poolId    String
  type      String
  earnedAt  DateTime @default(now())
  matchId   String?
  detail    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([userId, poolId, type])
  @@index([poolId, earnedAt])
}

model ChampionPick {
  id            String @id @default(cuid())
  userId        String
  poolId        String
  teamId        String
  pointsAwarded Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id])

  @@unique([userId, poolId])
}

model BonusQuestion {
  id            String            @id @default(cuid())
  poolId        String
  type          BonusQuestionType
  question      String
  description   String?
  options       String?
  category      String?
  orderIndex    Int               @default(0)
  correctAnswer String?
  deadline      DateTime?

  pool    Pool          @relation(fields: [poolId], references: [id], onDelete: Cascade)
  answers BonusAnswer[]

  @@index([poolId])
}

enum BonusQuestionType {
  OPEN
  ESTIMATION
  STATEMENT
}

model BonusAnswer {
  id            String   @id @default(cuid())
  userId        String
  questionId    String
  answer        String
  submittedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt
  pointsAwarded Int?

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  question BonusQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([questionId])
}

model PoolMessage {
  id        String   @id @default(cuid())
  poolId    String
  userId    String?
  content   String
  createdAt DateTime @default(now())
  isSystem  Boolean  @default(false)
  kind      String?

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([poolId, createdAt])
}

// ─── Wachtwoord reset ─────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─── Push notificaties ────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── WK Survivor ──────────────────────────────────────────────────────────────

model SurvivorEntry {
  id                String   @id @default(cuid())
  userId            String   @unique
  hardcoreAlive     Boolean  @default(true)
  hardcoreElimRound String?
  highscoreTotal    Int      @default(0)
  resetUsed         Boolean  @default(false)
  createdAt         DateTime @default(now())

  user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  picks SurvivorPick[]
}

model SurvivorPick {
  id       String   @id @default(cuid())
  entryId  String
  userId   String
  mode     String   // HARDCORE | HIGHSCORE
  teamId   String
  round    String   // GROUP_1 | GROUP_2 | GROUP_3 | ROUND_OF_32 | ROUND_OF_16 | QUARTER_FINAL | SEMI_FINAL | FINAL
  cycle    Int      @default(0) // HIGHSCORE: 0=before reset, 1=after reset
  result   String   @default("PENDING") // PENDING | SURVIVED | ELIMINATED
  goalDiff Int?
  pickedAt DateTime @default(now())

  entry SurvivorEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  team  Team          @relation(fields: [teamId], references: [id])

  @@unique([entryId, round, mode])
  @@unique([userId, mode, teamId, cycle])
  @@index([entryId])
  @@index([round])
}

model LeaderboardEntry {
  id               String   @id @default(cuid())
  userId           String
  poolId           String
  totalPoints         Int      @default(0)
  matchPoints         Int      @default(0)
  bonusPoints         Int      @default(0)
  championPoints      Int      @default(0)
  previousTotalPoints Int?
  snapshotAt          DateTime?
  lastCalculatedAt    DateTime @default(now())

  pool Pool @relation(fields: [poolId], references: [id], onDelete: Cascade)

  @@unique([userId, poolId])
  @@index([poolId, totalPoints(sort: Desc)])
}

// ─── Fantasy WK ───────────────────────────────────────────────────────────────

enum PlayerPosition {
  GK
  DEF
  MID
  FWD
}

model Player {
  id          String         @id @default(cuid())
  name        String
  nameNl      String?
  teamId      String
  position    PlayerPosition
  shirtNumber Int?
  photoUrl    String?
  isActive    Boolean        @default(true)
  externalId  Int?           @unique

  team  Team                 @relation(fields: [teamId], references: [id])
  stats FantasyPlayerStats[]
  picks FantasyPick[]

  @@index([teamId])
  @@index([position])
}

// Eén FantasyTeam per gebruiker (globaal, niet per pool)
model FantasyTeam {
  id          String   @id @default(cuid())
  userId      String   @unique
  nickname    String
  totalPoints Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  picks     FantasyPick[]
  transfers FantasyTransfer[]
}

// Huidige selectie: 15 spelers (2GK + 5DEF + 5MID + 3FWD)
model FantasyPick {
  id             String   @id @default(cuid())
  fantasyTeamId  String
  playerId       String
  addedInRound   String   // GROUP_1 | GROUP_2 | GROUP_3 | ROUND_OF_32 | ROUND_OF_16 | QUARTER_FINAL

  fantasyTeam FantasyTeam @relation(fields: [fantasyTeamId], references: [id], onDelete: Cascade)
  player      Player      @relation(fields: [playerId], references: [id])

  @@unique([fantasyTeamId, playerId])
  @@index([fantasyTeamId])
}

// Transferhistorie per speelronde (max 2 per ronde)
model FantasyTransfer {
  id            String   @id @default(cuid())
  fantasyTeamId String
  round         String   // GROUP_1 | GROUP_2 | ...
  playerOutId   String
  playerInId    String
  createdAt     DateTime @default(now())

  fantasyTeam FantasyTeam @relation(fields: [fantasyTeamId], references: [id], onDelete: Cascade)

  @@index([fantasyTeamId, round])
}

// Statistieken per speler per wedstrijd (gevuld door admin of API)
model FantasyPlayerStats {
  id                     String   @id @default(cuid())
  playerId               String
  matchId                String
  minutesPlayed          Int      @default(0)
  goals                  Int      @default(0)
  assists                Int      @default(0)
  cleanSheet             Boolean  @default(false)
  goalsConceded          Int      @default(0)
  shotsSaved             Int      @default(0)
  penaltySaved           Int      @default(0)
  penaltyMissed          Int      @default(0)
  yellowCards            Int      @default(0)
  redCards               Int      @default(0)
  ownGoals               Int      @default(0)
  bonusPoints            Int      @default(0)
  totalPoints            Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  player Player @relation(fields: [playerId], references: [id])
  match  Match  @relation(fields: [matchId], references: [id])

  @@unique([playerId, matchId])
  @@index([matchId])
  @@index([playerId])
}
